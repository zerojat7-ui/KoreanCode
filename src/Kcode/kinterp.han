 // ── 통계 함수 (배열 기반) ────────────────────────────────────────

    만약 이름 == "합계": // 합계(배열) or 합계(a, b, c, ...)
        배열 수들 = []
        만약 인수수 == 1 그리고 인수들[0]["타입"] == VAL_배열:
