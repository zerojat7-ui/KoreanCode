// kinterp.han — Kcode 인터프리터 구현
// version : v35.8.0
// kinterp.c (v23.0.0) 기반 Kcode 문법으로 재작성
// ★ 1단계: 값 시스템 + 환경 + 신호 + 리터럴 + 연산 + 변수
// ★ 2단계: 컨테이너 리터럴 + 인덱스/멤버 + 제어 흐름 (만약/동안/반복/각각/선택)
// ★ 3단계: 함수/정의 선언 + 호출 + 람다 + 메서드 + 내장 함수
// ★ 4단계: 자료구조 고차 메서드 + 문자열 확장 + 텐서 리터럴
// ★ 5단계: 수학 함수 21종 + 통계 6종 + 문자열 함수 17종 + 수학 상수 3종
// ★ 6단계: 객체(클래스) 선언 + 상속 + 인스턴스 생성 + 메서드 호출
// ★ 7단계: 예외처리(시도/실패시/항상) + goto/label
// ★ 8단계: 모듈(#포함/가짐) + 파일 I/O + 스크립트 블록 스텁
// ★ 9단계: §16-7-1 인라인 캐시 (함수 디스패치 O(탐색)→O(1) 캐시 히트)
// ★ 10단계: §16-7-2 .kwh 힌트 연동 (인라인 캐시 LFU 초기값 부스트)

#포함 "kinterp.hg"

// ================================================================
//  값 생성
// ================================================================

함수 값없음():
    반환 {
        "타입":   VAL_없음,
        "정수값": 0,
        "실수값": 0.0,
        "논리값": 거짓,
        "문자값": "",
        "참조값": 없음,
    }

함수 값만들기정수(정수 v):
    목록 val = 값없음()
    val["타입"] = VAL_정수
    val["정수값"] = v
    반환 val

함수 값만들기실수(실수 v):
    목록 val = 값없음()
    val["타입"] = VAL_실수
    val["실수값"] = v
    반환 val

함수 값만들기글자(정수 cp):
    목록 val = 값없음()
    val["타입"] = VAL_글자
    val["정수값"] = cp
    반환 val

함수 값만들기문자(문자 v):
    목록 val = 값없음()
    val["타입"] = VAL_문자
    val["문자값"] = v
    반환 val

함수 값만들기논리(논리 v):
    목록 val = 값없음()
    val["타입"] = VAL_논리
    val["논리값"] = v
    반환 val

함수 값만들기배열(배열 v):
    목록 val = 값없음()
    val["타입"] = VAL_배열
    val["참조값"] = v
    반환 val

함수 값만들기사전(목록 v):
    목록 val = 값없음()
    val["타입"] = VAL_사전
    val["참조값"] = v
    반환 val

함수 값만들기함수(목록 노드, 목록 클로저):
    목록 val = 값없음()
    val["타입"] = VAL_함수
    val["참조값"] = 목록 {
        "노드":   노드,
        "클로저": 클로저,
    }
    반환 val

함수 값만들기람다(목록 노드, 목록 클로저):
    목록 val = 값없음()
    val["타입"] = VAL_람다
    val["참조값"] = 목록 {
        "노드":   노드,
        "클로저": 클로저,
    }
    반환 val

함수 값만들기내장(문자 이름):
    목록 val = 값없음()
    val["타입"] = VAL_내장
    val["문자값"] = 이름
    반환 val

함수 값만들기클래스(문자 이름, 목록 노드):
    목록 val = 값없음()
    val["타입"] = VAL_클래스
    val["문자값"] = 이름
    val["참조값"] = 노드
    반환 val

// ================================================================
//  값 조회 / 변환
// ================================================================

함수 값타입이름(정수 타입):
    만약 VAL_타입이름 포함(타입):
        반환 VAL_타입이름[타입]
    반환 "알수없음"

함수 값문자열변환(목록 val):
    정수 t = val["타입"]
    만약 t == VAL_없음:   반환 "없음"
    만약 t == VAL_정수:   반환 문자(val["정수값"])
    만약 t == VAL_실수:   반환 문자(val["실수값"])
    만약 t == VAL_글자:   반환 문자(val["정수값"])
    만약 t == VAL_문자:   반환 val["문자값"]
    만약 t == VAL_논리:
        만약 val["논리값"]: 반환 "참"
        반환 "거짓"
    만약 t == VAL_배열:
        배열 arr = val["참조값"]
        정수 arr길이 = 길이(arr)
        만약 arr길이 == 0: 반환 "[]"
        문자 결과 = "["
        반복 i 부터 0 까지 arr길이:
            만약 i > 0: 결과 = 결과 + ", "
            결과 = 결과 + 값문자열변환(arr[i])
        반환 결과 + "]"
    만약 t == VAL_사전 또는 t == VAL_목록:
        목록 dict = val["참조값"]
        문자 결과 = "{"
        논리 첫째 = 참
        각각 키 안에 dict:
            만약 아니다 첫째: 결과 = 결과 + ", "
            결과 = 결과 + "\"" + 키 + "\": " + 값문자열변환(dict[키])
            첫째 = 거짓
        반환 결과 + "}"
    만약 t == VAL_객체:   반환 "<" + val["참조값"]["클래스명"] + " 객체>"
    만약 t == VAL_함수 또는 t == VAL_람다: 반환 "<함수>"
    만약 t == VAL_내장:   반환 "<내장:" + val["문자값"] + ">"
    만약 t == VAL_클래스: 반환 "<클래스:" + val["문자값"] + ">"
    반환 "알수없음"

함수 값참인지(목록 val):
    정수 t = val["타입"]
    만약 t == VAL_없음:  반환 거짓
    만약 t == VAL_논리:  반환 val["논리값"]
    만약 t == VAL_정수:  반환 val["정수값"] != 0
    만약 t == VAL_실수:  반환 val["실수값"] != 0.0
    만약 t == VAL_문자:  반환 길이(val["문자값"]) > 0
    만약 t == VAL_글자:  반환 val["정수값"] != 0
    만약 t == VAL_배열:  반환 길이(val["참조값"]) > 0
    반환 참

함수 값같은지(목록 가, 목록 나): // 정수-실수 혼합 비교
    만약 가["타입"] != 나["타입"]:
        만약 가["타입"] == VAL_정수 그리고 나["타입"] == VAL_실수:
            반환 실수(가["정수값"]) == 나["실수값"]
        만약 가["타입"] == VAL_실수 그리고 나["타입"] == VAL_정수:
            반환 가["실수값"] == 실수(나["정수값"])
        반환 거짓
    정수 t = 가["타입"]
    만약 t == VAL_없음:  반환 참
    만약 t == VAL_정수 또는 t == VAL_글자:
        반환 가["정수값"] == 나["정수값"]
    만약 t == VAL_실수:  반환 가["실수값"] == 나["실수값"]
    만약 t == VAL_논리:  반환 가["논리값"] == 나["논리값"]
    만약 t == VAL_문자:  반환 가["문자값"] == 나["문자값"] // 배열, 사전, 객체 → 참조 동일성
    반환 가["참조값"] == 나["참조값"]

// ================================================================
//  실행 신호
// ================================================================

함수 신호정상(목록 val):
    반환 {
        "종류":       SIG_정상,
        "값":         val,
        "오류코드":   ERR_없음,
        "오류메시지": "",
        "이동목표":   "",
    }

함수 신호반환(목록 val):
    반환 {
        "종류":       SIG_반환,
        "값":         val,
        "오류코드":   ERR_없음,
        "오류메시지": "",
        "이동목표":   "",
    }

함수 신호끝냄():
    반환 {
        "종류":       SIG_끝냄,
        "값":         값없음(),
        "오류코드":   ERR_없음,
        "오류메시지": "",
        "이동목표":   "",
    }

함수 신호멈춤():
    반환 {
        "종류":       SIG_멈춤,
        "값":         값없음(),
        "오류코드":   ERR_없음,
        "오류메시지": "",
        "이동목표":   "",
    }

함수 신호건너뜀():
    반환 {
        "종류":       SIG_건너뜀,
        "값":         값없음(),
        "오류코드":   ERR_없음,
        "오류메시지": "",
        "이동목표":   "",
    }

함수 신호이동(문자 목표):
    반환 {
        "종류":       SIG_이동,
        "값":         값없음(),
        "오류코드":   ERR_없음,
        "오류메시지": "",
        "이동목표":   목표,
    }

함수 신호오류(정수 코드, 문자 메시지):
    반환 {
        "종류":       SIG_오류,
        "값":         값없음(),
        "오류코드":   코드,
        "오류메시지": "[런타임 오류] " + 메시지,
        "이동목표":   "",
    }

함수 신호오류위치(정수 코드, 문자 메시지, 정수 줄, 정수 열):
    반환 신호오류(코드,
        "줄 " + 문자(줄) + ", 열 " + 문자(열) + " — " + 메시지)

함수 신호오류인지(목록 신호):
    반환 신호["종류"] == SIG_오류

함수 신호전파인지(목록 신호): // 정상이 아닌 모든 신호는 블록 밖으로 전파
    반환 신호["종류"] != SIG_정상

// ================================================================
//  환경(스코프)
// ================================================================

함수 환경만들기(목록 부모):
    반환 {
        "변수들": 목록 {},
        "부모":   부모,
    }

정의 환경변수정의(목록 환경, 문자 이름, 목록 val, 논리 상수):
    환경["변수들"][이름] = 목록 {
        "값":   val,
        "상수": 상수,
    }

함수 환경변수대입(목록 환경, 문자 이름, 목록 val):
    목록 현재 = 환경
    동안 현재 != 없음:
        만약 현재["변수들"] 포함(이름):
            만약 현재["변수들"][이름]["상수"]:
                반환 거짓   // 상수 재대입 불가
            현재["변수들"][이름]["값"] = val
            반환 참
        현재 = 현재["부모"]
    반환 거짓

함수 환경변수조회(목록 환경, 문자 이름):
    목록 현재 = 환경
    동안 현재 != 없음:
        만약 현재["변수들"] 포함(이름):
            반환 현재["변수들"][이름]["값"]
        현재 = 현재["부모"]
    반환 없음

함수 환경변수존재(목록 환경, 문자 이름):
    목록 현재 = 환경
    동안 현재 != 없음:
        만약 현재["변수들"] 포함(이름):
            반환 참
        현재 = 현재["부모"]
    반환 거짓

// ================================================================
// ★ 9단계: §16-7-1 인라인 캐시
// ================================================================
// 함수 이름 → 함수값 직접 저장 (LFU 교체)
// 캐시 히트 시 환경 체인 탐색 생략 → O(1) 디스패치
// 결정론 보장: 캐시 유무와 무관하게 실행 결과 동일

// ── 슬롯 1개 초기화 ──────────────────────────────────────────────
함수 캐시슬롯만들기():
    반환 {
        "이름":   "",
        "함수값": 없음,
        "히트수": 0,
    }

// ── 캐시 조회: 이름 → 함수값 (미스 시 없음) ─────────────────────
함수 캐시조회(목록 인터프리터, 문자 이름):
    배열 슬롯들 = 인터프리터["인라인캐시"]
    반복 i 부터 0 까지 KCODE_ICACHE_SLOTS:
        만약 슬롯들[i]["이름"] == 이름:
            슬롯들[i]["히트수"] = 슬롯들[i]["히트수"] + 1
            반환 슬롯들[i]["함수값"]
    반환 없음

// ── 캐시 갱신: 이름 + 함수값 등록 (LFU 교체) ────────────────────
함수 캐시갱신(목록 인터프리터, 문자 이름, 목록 함수값):
    배열 슬롯들 = 인터프리터["인라인캐시"]
 // 빈 슬롯 우선 사용
    반복 i 부터 0 까지 KCODE_ICACHE_SLOTS:
        만약 슬롯들[i]["이름"] == "":
            슬롯들[i]["이름"]   = 이름
            슬롯들[i]["함수값"] = 함수값
            슬롯들[i]["히트수"] = kwh초기히트(인터프리터, 이름)  // §16-7-2: kw힌트 부스트
            반환
 // 모든 슬롯 사용 중 — 히트수 최저 슬롯 교체 (LFU)
    정수 최저 = 0
    반복 i 부터 1 까지 KCODE_ICACHE_SLOTS:
        만약 슬롯들[i]["히트수"] < 슬롯들[최저]["히트수"]:
            최저 = i

    슬롯들[최저]["이름"]   = 이름
    슬롯들[최저]["함수값"] = 함수값
    슬롯들[최저]["히트수"] = kwh초기히트(인터프리터, 이름)  // §16-7-2: kw힌트 부스트

// ── 캐시 무효화: 이름에 해당하는 슬롯 제거 (재정의 시 호출) ─────
함수 캐시무효화(목록 인터프리터, 문자 이름):
    배열 슬롯들 = 인터프리터["인라인캐시"]
    반복 i 부터 0 까지 KCODE_ICACHE_SLOTS:
        만약 슬롯들[i]["이름"] == 이름:
            슬롯들[i]["이름"]   = ""
            슬롯들[i]["함수값"] = 없음
            슬롯들[i]["히트수"] = 0
            반환

// ================================================================
// ★ 10단계: §16-7-2 .kwh 힌트 연동
// ================================================================
// .kwh 텍스트 사이드카 — 이전 실행 히트수 → 인라인 캐시 LFU 초기값 부스트
// 포맷: "# Kcode Weight Hint v1\n함수이름=히트수\n..."
// 시작 시: .kwh 읽기 → kw힌트 사전 로드
// 종료 시: 캐시 슬롯 히트수 → .kwh 저장

// ── .kwh 경로: "foo.han" → "foo.kwh" ─────────────────────────────
함수 kwh경로(문자 경로):
    배열 부분들 = 분리(경로, ".")
    정수 n = 길이(부분들)
    만약 n > 1:
        문자 기본 = ""
        반복 i 부터 0 까지 n - 1:
            만약 i > 0: 기본 = 기본 + "."
            기본 = 기본 + 부분들[i]
        반환 기본 + ".kwh"
    반환 경로 + ".kwh"

// ── .kwh 읽기: 텍스트 파싱 → {이름: 히트수} 사전 ──────────────────
함수 kwh읽기(문자 파일경로):
    목록 힌트 = 목록 {}
    만약 아니다 파일있음(파일경로):
        반환 힌트
    문자 내용 = 파일전체읽기(파일경로)
    배열 줄들 = 분리(내용, "\n")
    각각 한줄 안에 줄들:
        한줄 = 다듬기(한줄)
        만약 아니다 포함(한줄, "="):
            건너뜀    // 빈 줄 또는 # 주석
        배열 부분들 = 분리(한줄, "=")
        만약 길이(부분들) >= 2:
            문자 fn이름 = 다듬기(부분들[0])
            문자 fn값문자 = 다듬기(부분들[1])
            만약 길이(fn이름) > 0 그리고 길이(fn값문자) > 0:
                정수 fn히트 = 정수(fn값문자)
                만약 fn히트 > 0:
                    힌트[fn이름] = fn히트
    반환 힌트

// ── .kwh 쓰기: 캐시 슬롯 히트수 → 텍스트 파일 ───────────────────
정의 kwh쓰기(문자 파일경로, 목록 인터프리터):
    배열 슬롯들 = 인터프리터["인라인캐시"]
    문자 내용 = "# Kcode Weight Hint v1\n"
    반복 i 부터 0 까지 KCODE_ICACHE_SLOTS:
        만약 슬롯들[i]["이름"] != "" 그리고 슬롯들[i]["히트수"] > 0:
            내용 = 내용 + 슬롯들[i]["이름"] + "=" + 문자(슬롯들[i]["히트수"]) + "\n"
    파일전체쓰기(파일경로, 내용)

// ── kw힌트 초기 히트수: 이전 히트수+1 반환 (없으면 1) ────────────
함수 kwh초기히트(목록 인터프리터, 문자 이름):
    목록 힌트 = 인터프리터["kw힌트"]
    만약 힌트 포함(이름):
        반환 힌트[이름] + 1
    반환 1

// ── kwh 적재: 인터프리터 시작 시 .kwh → kw힌트 로드 ─────────────
정의 kwh적재(목록 인터프리터):
    문자 경로 = 인터프리터["스크립트경로"]
    만약 길이(경로) == 0:
        반환
    목록 힌트 = kwh읽기(kwh경로(경로))
    인터프리터["kw힌트"] = 힌트

// ── kwh 저장: 인터프리터 종료 시 캐시 히트수 → .kwh 저장 ─────────
정의 kwh저장(목록 인터프리터):
    문자 경로 = 인터프리터["스크립트경로"]
    만약 길이(경로) == 0:
        반환
    kwh쓰기(kwh경로(경로), 인터프리터)

// ================================================================
//  인터프리터 초기화
// ================================================================

함수 인터프리터만들기():
    목록 글로벌 = 환경만들기(없음) // ── 기본 입출력 / 변환 ──────────────────────────────
    환경변수정의(전역, "출력",    값만들기내장("출력"),    거짓)
    환경변수정의(전역, "출력없이",값만들기내장("출력없이"),거짓)
    환경변수정의(전역, "입력",    값만들기내장("입력"),    거짓)
    환경변수정의(전역, "길이",    값만들기내장("길이"),    거짓)
    환경변수정의(전역, "문자",    값만들기내장("문자"),    거짓)
    환경변수정의(전역, "정수",    값만들기내장("정수"),    거짓)
    환경변수정의(전역, "실수",    값만들기내장("실수"),    거짓)
    환경변수정의(전역, "글자",    값만들기내장("글자"),    거짓)
    환경변수정의(전역, "코드",    값만들기내장("코드"),    거짓)
    환경변수정의(전역, "유형",    값만들기내장("유형"),    거짓)
    환경변수정의(전역, "복사",    값만들기내장("복사"),    거짓)
    환경변수정의(전역, "범위",    값만들기내장("범위"),    거짓)
 // ── 5단계: 수학 상수 ────────────────────────────────
    환경변수정의(전역, "파이",      값만들기실수(3.14159265358979), 참)
    환경변수정의(전역, "오일러",    값만들기실수(2.71828182845905), 참)
    환경변수정의(전역, "무한대",    값만들기실수(1.7976931348623e308), 참)
 // ── 5단계: 수학 함수 ────────────────────────────────
    환경변수정의(전역, "절대",      값만들기내장("절대"),      거짓)
    환경변수정의(전역, "올림",      값만들기내장("올림"),      거짓)
    환경변수정의(전역, "내림",      값만들기내장("내림"),      거짓)
    환경변수정의(전역, "반올림",    값만들기내장("반올림"),    거짓)
    환경변수정의(전역, "최대",      값만들기내장("최대"),      거짓)
    환경변수정의(전역, "최소",      값만들기내장("최소"),      거짓)
    환경변수정의(전역, "제곱근",    값만들기내장("제곱근"),    거짓)
    환경변수정의(전역, "로그",      값만들기내장("로그"),      거짓)
    환경변수정의(전역, "자연로그",  값만들기내장("자연로그"),  거짓)
    환경변수정의(전역, "지수",      값만들기내장("지수"),      거짓)
    환경변수정의(전역, "사인",      값만들기내장("사인"),      거짓)
    환경변수정의(전역, "코사인",    값만들기내장("코사인"),    거짓)
    환경변수정의(전역, "탄젠트",    값만들기내장("탄젠트"),    거짓)
    환경변수정의(전역, "라디안",    값만들기내장("라디안"),    거짓)
    환경변수정의(전역, "각도",      값만들기내장("각도"),      거짓)
    환경변수정의(전역, "난수",      값만들기내장("난수"),      거짓)
    환경변수정의(전역, "난정수",    값만들기내장("난정수"),    거짓)
    환경변수정의(전역, "아크사인",  값만들기내장("아크사인"),  거짓)
    환경변수정의(전역, "아크코사인",값만들기내장("아크코사인"),거짓)
    환경변수정의(전역, "아크탄젠트",값만들기내장("아크탄젠트"),거짓)
    환경변수정의(전역, "아크탄젠트2",값만들기내장("아크탄젠트2"),거짓)
 // ── 5단계: 통계 함수 ────────────────────────────────
    환경변수정의(전역, "합계",      값만들기내장("합계"),      거짓)
    환경변수정의(전역, "평균",      값만들기내장("평균"),      거짓)
    환경변수정의(전역, "분산",      값만들기내장("분산"),      거짓)
    환경변수정의(전역, "표준편차",  값만들기내장("표준편차"),  거짓)
    환경변수정의(전역, "중앙값",    값만들기내장("중앙값"),    거짓)
    환경변수정의(전역, "최빈값",    값만들기내장("최빈값"),    거짓)
 // ── 5단계: 문자열 함수 (스펙명 → 호스트명 위임) ────
    환경변수정의(전역, "찾기",      값만들기내장("찾기"),      거짓)
    환경변수정의(전역, "포함",      값만들기내장("포함"),      거짓)
    환경변수정의(전역, "시작",      값만들기내장("시작"),      거짓)
    환경변수정의(전역, "끝",        값만들기내장("끝"),        거짓)
    환경변수정의(전역, "자르기",    값만들기내장("자르기"),    거짓)
    환경변수정의(전역, "좌문자",    값만들기내장("좌문자"),    거짓)
    환경변수정의(전역, "우문자",    값만들기내장("우문자"),    거짓)
    환경변수정의(전역, "바꾸기",    값만들기내장("바꾸기"),    거짓)
    환경변수정의(전역, "분리",      값만들기내장("분리"),      거짓)
    환경변수정의(전역, "합치기",    값만들기내장("합치기"),    거짓)
    환경변수정의(전역, "뒤집기",    값만들기내장("뒤집기"),    거짓)
    환경변수정의(전역, "되풀이",    값만들기내장("되풀이"),    거짓)
    환경변수정의(전역, "채우기",    값만들기내장("채우기"),    거짓)
    환경변수정의(전역, "붙여씀",    값만들기내장("붙여씀"),    거짓)
    환경변수정의(전역, "대문자",    값만들기내장("대문자"),    거짓)
    환경변수정의(전역, "소문자",    값만들기내장("소문자"),    거짓)
    환경변수정의(전역, "다듬기",    값만들기내장("다듬기"),    거짓)
    환경변수정의(전역, "앞공백",    값만들기내장("앞공백"),    거짓)
    환경변수정의(전역, "뒷공백",    값만들기내장("뒷공백"),    거짓)
    환경변수정의(전역, "제목식",    값만들기내장("제목식"),    거짓)
 // ── 8단계: 파일 I/O + 시스템 ─────────────────────────
    환경변수정의(전역, "파일전체읽기",  값만들기내장("파일전체읽기"),  거짓)
    환경변수정의(전역, "파일전체쓰기",  값만들기내장("파일전체쓰기"),  거짓)
    환경변수정의(전역, "명령실행",      값만들기내장("명령실행"),      거짓)
    환경변수정의(전역, "파일있음",      값만들기내장("파일있음"),      거짓)
    환경변수정의(전역, "파일지우기",    값만들기내장("파일지우기"),    거짓)
    환경변수정의(전역, "파일복사",      값만들기내장("파일복사"),      거짓)
    환경변수정의(전역, "파일이동",      값만들기내장("파일이동"),      거짓)
    환경변수정의(전역, "파일목록",      값만들기내장("파일목록"),      거짓)
    환경변수정의(전역, "파일크기",      값만들기내장("파일크기"),      거짓)
    환경변수정의(전역, "파일이름",      값만들기내장("파일이름"),      거짓)
    환경변수정의(전역, "파일확장자",    값만들기내장("파일확장자"),    거짓)
 // ── 9단계: 인라인 캐시 초기화 ───────────────────────────
    배열 캐시슬롯들 = []
    반복 _i 부터 0 까지 KCODE_ICACHE_SLOTS:
        캐시슬롯들 추가(캐시슬롯만들기())

    반환 {
        "전역환경":    전역,
        "호출깊이":    0,
        "오류있음":    거짓,
        "오류목록":    [],
        "인라인캐시":  캐시슬롯들,    // §16-7-1: 함수 디스패치 캐시
        "스크립트경로": "",            // §16-7-2: .kwh 사이드카 경로 기반
        "kw힌트":      목록 {},        // §16-7-2: 이전 실행 히트수 (kwh적재 시 채워짐)
    }

// ================================================================
//  숫자 이항 연산 보조
// ================================================================

함수 숫자이항연산(목록 좌, 목록 우, 정수 연산자):
    논리 실수모드 = 좌["타입"] == VAL_실수 또는 우["타입"] == VAL_실수
    실수 가 = 0.0
    실수 나 = 0.0
    만약 실수모드:
        만약 좌["타입"] == VAL_실수: 가 = 좌["실수값"]
        아니면:                      가 = 실수(좌["정수값"])
        만약 우["타입"] == VAL_실수: 나 = 우["실수값"]
        아니면:                      나 = 실수(우["정수값"])
    아니면:
        가 = 실수(좌["정수값"])
        나 = 실수(우["정수값"])

    만약 연산자 == TOK_PLUS:
        만약 실수모드: 반환 값만들기실수(가 + 나)
        반환 값만들기정수(정수(가) + 정수(나))
    만약 연산자 == TOK_MINUS:
        만약 실수모드: 반환 값만들기실수(가 - 나)
        반환 값만들기정수(정수(가) - 정수(나))
    만약 연산자 == TOK_STAR:
        만약 실수모드: 반환 값만들기실수(가 * 나)
        반환 값만들기정수(정수(가) * 정수(나))
    만약 연산자 == TOK_SLASH:
        만약 나 == 0.0: 반환 없음   // 호출 측에서 오류 처리
        만약 실수모드:  반환 값만들기실수(가 / 나)
        반환 값만들기정수(정수(가) / 정수(나))
    만약 연산자 == TOK_PERCENT:
        만약 나 == 0.0: 반환 없음
        반환 값만들기정수(정수(가) % 정수(나))
    만약 연산자 == TOK_STARSTAR:
        반환 값만들기실수(제곱(가, 나))
    반환 없음

함수 숫자비교연산(목록 좌, 목록 우, 정수 연산자):
    실수 가 = 0.0
    실수 나 = 0.0
    만약 좌["타입"] == VAL_실수: 가 = 좌["실수값"]
    아니면:                      가 = 실수(좌["정수값"])
    만약 우["타입"] == VAL_실수: 나 = 우["실수값"]
    아니면:                      나 = 실수(우["정수값"])
    만약 연산자 == TOK_GT:   반환 값만들기논리(가 >  나)
    만약 연산자 == TOK_LT:   반환 값만들기논리(가 <  나)
    만약 연산자 == TOK_GTEQ: 반환 값만들기논리(가 >= 나)
    만약 연산자 == TOK_LTEQ: 반환 값만들기논리(가 <= 나)
    반환 없음

// ================================================================
//  이항 연산 (NODE_BINARY)
// ================================================================

함수 이항연산평가(목록 인터프리터, 목록 환경, 목록 노드):
    정수 연산자 = 노드["연산자"]
    목록 좌노드 = 노드["자식들"][0]
    목록 우노드 = 노드["자식들"][1]
    정수 줄 = 노드["줄"]
    정수 열 = 노드["열"]
 // 단락 평가: 그리고
    만약 연산자 == TOK_KW_AND:
        목록 sg = 노드평가(인터프리터, 환경, 좌노드)
        만약 신호오류인지(sg): 반환 sg
        만약 아니다 값참인지(sg["값"]):
            반환 신호정상(값만들기논리(거짓))
        sg = 노드평가(인터프리터, 환경, 우노드)
        만약 신호오류인지(sg): 반환 sg
        반환 신호정상(값만들기논리(값참인지(sg["값"])))
 // 단락 평가: 또는
    만약 연산자 == TOK_KW_OR:
        목록 sg = 노드평가(인터프리터, 환경, 좌노드)
        만약 신호오류인지(sg): 반환 sg
        만약 값참인지(sg["값"]):
            반환 신호정상(값만들기논리(참))
        sg = 노드평가(인터프리터, 환경, 우노드)
        만약 신호오류인지(sg): 반환 sg
        반환 신호정상(값만들기논리(값참인지(sg["값"])))
 // 양쪽 먼저 평가
    목록 sg좌 = 노드평가(인터프리터, 환경, 좌노드)
    만약 신호오류인지(sg좌): 반환 sg좌
    목록 sg우 = 노드평가(인터프리터, 환경, 우노드)
    만약 신호오류인지(sg우): 반환 sg우
    목록 좌 = sg좌["값"]
    목록 우 = sg우["값"]
 // == !=
    만약 연산자 == TOK_EQEQ:
        반환 신호정상(값만들기논리(값같은지(좌, 우)))
    만약 연산자 == TOK_BANGEQ:
        반환 신호정상(값만들기논리(아니다 값같은지(좌, 우)))
 // 문자열 연결 (+)
    만약 연산자 == TOK_PLUS 그리고
         (좌["타입"] == VAL_문자 또는 우["타입"] == VAL_문자):
        반환 신호정상(값만들기문자(값문자열변환(좌) + 값문자열변환(우)))
 // 숫자 산술 / 비교
    논리 좌숫자 = 좌["타입"] == VAL_정수 또는 좌["타입"] == VAL_실수
    논리 우숫자 = 우["타입"] == VAL_정수 또는 우["타입"] == VAL_실수
    만약 좌숫자 그리고 우숫자:
        만약 연산자 == TOK_PLUS 또는 연산자 == TOK_MINUS 또는
             연산자 == TOK_STAR 또는 연산자 == TOK_SLASH 또는
             연산자 == TOK_PERCENT 또는 연산자 == TOK_STARSTAR:
            목록 결과 = 숫자이항연산(좌, 우, 연산자)
            만약 결과 == 없음:
                반환 신호오류위치(ERR_영나누기, "0으로 나눌 수 없습니다", 줄, 열)
            반환 신호정상(결과)
        만약 연산자 == TOK_GT 또는 연산자 == TOK_LT 또는
             연산자 == TOK_GTEQ 또는 연산자 == TOK_LTEQ:
            목록 결과 = 숫자비교연산(좌, 우, 연산자)
            만약 결과 == 없음:
                반환 신호오류위치(ERR_타입, "비교 연산 오류", 줄, 열)
            반환 신호정상(결과)
 // 비트 연산 (정수만)
    만약 좌["타입"] == VAL_정수 그리고 우["타입"] == VAL_정수:
        정수 가 = 좌["정수값"]
        정수 나 = 우["정수값"]
        만약 연산자 == TOK_AMP:   반환 신호정상(값만들기정수(가 &  나))
        만약 연산자 == TOK_PIPE:  반환 신호정상(값만들기정수(가 |  나))
        만약 연산자 == TOK_CARET: 반환 신호정상(값만들기정수(가 ^  나))
        만약 연산자 == TOK_LTLT:  반환 신호정상(값만들기정수(가 << 나))
        만약 연산자 == TOK_GTGT:  반환 신호정상(값만들기정수(가 >> 나))

    반환 신호오류위치(ERR_타입,
        "'" + 값타입이름(좌["타입"]) + "' 와 '" +
        값타입이름(우["타입"]) + "' 간 연산 불가",
        줄, 열)

// ================================================================
//  단항 연산 (NODE_UNARY)
// ================================================================

함수 단항연산평가(목록 인터프리터, 목록 환경, 목록 노드):
    목록 sg = 노드평가(인터프리터, 환경, 노드["자식들"][0])
    만약 신호오류인지(sg): 반환 sg
    목록 val = sg["값"]
    정수 연산자 = 노드["연산자"]
    정수 줄 = 노드["줄"]
    정수 열 = 노드["열"]

    만약 연산자 == TOK_MINUS:
        만약 val["타입"] == VAL_정수:
            반환 신호정상(값만들기정수(-val["정수값"]))
        만약 val["타입"] == VAL_실수:
            반환 신호정상(값만들기실수(-val["실수값"]))
        반환 신호오류위치(ERR_타입, "'-' 단항 연산은 숫자에만 사용 가능합니다", 줄, 열)

    만약 연산자 == TOK_KW_NOT:
        반환 신호정상(값만들기논리(아니다 값참인지(val)))

    만약 연산자 == TOK_TILDE:
        만약 val["타입"] == VAL_정수:
            반환 신호정상(값만들기정수(~val["정수값"]))
        반환 신호오류위치(ERR_타입, "'~' 비트 반전은 정수에만 사용 가능합니다", 줄, 열)

    반환 신호오류위치(ERR_내부, "알 수 없는 단항 연산자입니다", 줄, 열)

// ================================================================
//  변수 선언 (NODE_VAR_DECL / NODE_CONST_DECL)
// ================================================================

함수 변수선언실행(목록 인터프리터, 목록 환경, 목록 노드):
    논리 상수 = 노드["종류"] == NODE_CONST_DECL
    문자 이름 = 노드["문자열"]
    목록 val = 값없음()
    만약 길이(노드["자식들"]) > 0:
        목록 sg = 노드평가(인터프리터, 환경, 노드["자식들"][0])
        만약 신호오류인지(sg): 반환 sg
        val = sg["값"]
    환경변수정의(환경, 이름, val, 상수)
    반환 신호정상(값없음())

// ================================================================
//  대입 (NODE_ASSIGN)
// ================================================================

함수 대입평가(목록 인터프리터, 목록 환경, 목록 노드):
    정수 연산자 = 노드["연산자"]
    목록 좌노드 = 노드["자식들"][0]
    목록 우노드 = 노드["자식들"][1]
    정수 줄 = 노드["줄"]
    정수 열 = 노드["열"]
 // 우변 평가
    목록 sg우 = 노드평가(인터프리터, 환경, 우노드)
    만약 신호오류인지(sg우): 반환 sg우
    목록 우값 = sg우["값"]
 // 복합 대입 (+= -= *= /= %=) → 좌변 현재값과 연산
    만약 연산자 != TOK_EQ:
        목록 sg좌 = 노드평가(인터프리터, 환경, 좌노드)
        만약 신호오류인지(sg좌): 반환 sg좌
        목록 좌값 = sg좌["값"]
        정수 산술 = TOK_PLUS
        만약 연산자 == TOK_MINUSEQ:   산술 = TOK_MINUS
        아니면 만약 연산자 == TOK_STAREQ:    산술 = TOK_STAR
        아니면 만약 연산자 == TOK_SLASHEQ:   산술 = TOK_SLASH
        아니면 만약 연산자 == TOK_PERCENTEQ: 산술 = TOK_PERCENT // 임시 이항 노드로 계산
        목록 임시 = 목록 {
            "종류":    NODE_BINARY,
            "줄":      줄,
            "열":      열,
            "자식들":  [좌노드, 우노드],
            "연산자":  산술,
            "정수값":  0,
            "실수값":  0.0,
            "논리값":  0,
            "문자열":  없음,
            "자료형":  TOK_EOF,
        }
        목록 sg결과 = 이항연산평가(인터프리터, 환경, 임시)
        만약 신호오류인지(sg결과): 반환 sg결과
        우값 = sg결과["값"]
 // 단순 식별자 대입
    만약 좌노드["종류"] == NODE_IDENT:
        문자 이름 = 좌노드["문자열"]
        만약 아니다 환경변수존재(환경, 이름):
            환경변수정의(환경, 이름, 우값, 거짓)
            반환 신호정상(우값)
        만약 아니다 환경변수대입(환경, 이름, 우값):
            반환 신호오류위치(ERR_재정의,
                "상수 '" + 이름 + "' 에는 값을 대입할 수 없습니다", 줄, 열) // §16-7-1: 함수값 재대입 시 캐시 무효화
        정수 우타입 = 우값["타입"]
        만약 우타입 == VAL_함수 또는 우타입 == VAL_람다 또는 우타입 == VAL_내장:
            캐시무효화(인터프리터, 이름)
        반환 신호정상(우값)
 // 인덱스 대입: 배열[i] = 값, 사전["키"] = 값
    만약 좌노드["종류"] == NODE_INDEX:
        목록 sg대상 = 노드평가(인터프리터, 환경, 좌노드["자식들"][0])
        만약 신호오류인지(sg대상): 반환 sg대상
        목록 sg키 = 노드평가(인터프리터, 환경, 좌노드["자식들"][1])
        만약 신호오류인지(sg키): 반환 sg키
        목록 대상 = sg대상["값"]
        목록 키값 = sg키["값"]
        만약 대상["타입"] == VAL_배열:
            만약 키값["타입"] != VAL_정수:
                반환 신호오류위치(ERR_타입, "배열 인덱스는 정수여야 합니다", 줄, 열)
            정수 인덱스 = 키값["정수값"]
            정수 배열길이 = 길이(대상["참조값"])
            만약 인덱스 < 0: 인덱스 = 배열길이 + 인덱스
            만약 인덱스 < 0 또는 인덱스 >= 배열길이:
                반환 신호오류위치(ERR_범위,
                    "배열 인덱스 " + 문자(인덱스) + " 가 범위를 벗어났습니다", 줄, 열)
            대상["참조값"][인덱스] = 우값
            반환 신호정상(우값)
        만약 대상["타입"] == VAL_사전:
            문자 키문자 = 값문자열변환(키값)
            대상["참조값"][키문자] = 우값
            반환 신호정상(우값)
        반환 신호오류위치(ERR_타입,
            "'" + 값타입이름(대상["타입"]) + "' 는 인덱스 대입을 지원하지 않습니다", 줄, 열)
 // 멤버 대입: 목록.속성 = 값, 객체.속성 = 값
    만약 좌노드["종류"] == NODE_MEMBER:
        목록 sg대상 = 노드평가(인터프리터, 환경, 좌노드["자식들"][0])
        만약 신호오류인지(sg대상): 반환 sg대상
        목록 대상 = sg대상["값"]
        문자 멤버명 = 좌노드["문자열"]
        만약 대상["타입"] == VAL_사전 또는 대상["타입"] == VAL_목록:
            대상["참조값"][멤버명] = 우값
            반환 신호정상(우값)
        만약 대상["타입"] == VAL_객체:
            대상["참조값"]["필드"][멤버명] = 우값
            반환 신호정상(우값)
        반환 신호오류위치(ERR_타입,
            "'" + 값타입이름(대상["타입"]) + "' 는 멤버 대입을 지원하지 않습니다", 줄, 열)

    반환 신호오류위치(ERR_내부,
        "대입 좌변 '" + 노드이름(좌노드["종류"]) + "' 은 지원되지 않습니다", 줄, 열)

// ================================================================
//  노드 평가 (표현식) — 메인 디스패치
// ================================================================

함수 노드평가(목록 인터프리터, 목록 환경, 목록 노드):
    만약 노드 == 없음:
        반환 신호정상(값없음())
    정수 종류 = 노드["종류"]
 // ── 리터럴 ───────────────────────────────────────────
    만약 종류 == NODE_INT_LIT:
        반환 신호정상(값만들기정수(노드["정수값"]))
    만약 종류 == NODE_FLOAT_LIT:
        반환 신호정상(값만들기실수(노드["실수값"]))
    만약 종류 == NODE_STRING_LIT:
        반환 신호정상(값만들기문자(노드["문자열"]))
    만약 종류 == NODE_CHAR_LIT:
        반환 신호정상(값만들기글자(노드["문자값"]))
    만약 종류 == NODE_BOOL_LIT:
        반환 신호정상(값만들기논리(노드["논리값"] != 0))
    만약 종류 == NODE_NULL_LIT:
        반환 신호정상(값없음())
 // ── 식별자 ───────────────────────────────────────────
    만약 종류 == NODE_IDENT:
        문자 이름 = 노드["문자열"]
        목록 val = 환경변수조회(환경, 이름)
        만약 val == 없음:
            반환 신호오류위치(ERR_미정의,
                "'" + 이름 + "' 은(는) 정의되지 않았습니다",
                노드["줄"], 노드["열"])
        반환 신호정상(val)
 // ── 연산 ────────────────────────────────────────────
    만약 종류 == NODE_BINARY:
        반환 이항연산평가(인터프리터, 환경, 노드)
    만약 종류 == NODE_UNARY:
        반환 단항연산평가(인터프리터, 환경, 노드)
    만약 종류 == NODE_ASSIGN:
        반환 대입평가(인터프리터, 환경, 노드)
 // ── 2단계: 컨테이너 리터럴 ──────────────────────────
    만약 종류 == NODE_ARRAY_LIT:
        반환 배열리터럴평가(인터프리터, 환경, 노드)
    만약 종류 == NODE_DICT_LIT:
        반환 사전리터럴평가(인터프리터, 환경, 노드)
 // ── 2단계: 접근 ──────────────────────────────────────
    만약 종류 == NODE_INDEX:
        반환 인덱스평가(인터프리터, 환경, 노드)
    만약 종류 == NODE_MEMBER:
        반환 멤버평가(인터프리터, 환경, 노드)
 // ── 3단계: 함수 호출 / 람다 ─────────────────────────
    만약 종류 == NODE_CALL:
        반환 호출평가(인터프리터, 환경, 노드)
    만약 종류 == NODE_LAMBDA:
        반환 람다평가(인터프리터, 환경, 노드)
 // ── 4단계: 텐서 리터럴 ──────────────────────────────
    만약 종류 == NODE_TENSOR_LIT:
        반환 배열리터럴평가(인터프리터, 환경, 노드)
 // ── 나머지는 이후 단계에서 구현 ─────────────────────
    반환 신호오류위치(ERR_내부,
        "미구현 표현식 노드 '" + 노드이름(종류) + "'",
        노드["줄"], 노드["열"])

// ================================================================
//  배열 리터럴 평가 (NODE_ARRAY_LIT)
// ================================================================

함수 배열리터럴평가(목록 인터프리터, 목록 환경, 목록 노드):
    배열 결과 = []
    각각 항목노드 안에 노드["자식들"]:
        목록 sg = 노드평가(인터프리터, 환경, 항목노드)
        만약 신호오류인지(sg): 반환 sg
        결과 추가(sg["값"])
    반환 신호정상(값만들기배열(결과))

// ================================================================
//  사전 리터럴 평가 (NODE_DICT_LIT)
//  목록 { ... } 과 사전 { ... } 모두 처리
// ================================================================

함수 사전리터럴평가(목록 인터프리터, 목록 환경, 목록 노드):
    목록 결과 = 목록 {}
    각각 항목노드 안에 노드["자식들"]: // NODE_DICT_ENTRY: child[0]=키, child[1]=값
        목록 sg키 = 노드평가(인터프리터, 환경, 항목노드["자식들"][0])
        만약 신호오류인지(sg키): 반환 sg키
        목록 sg값 = 노드평가(인터프리터, 환경, 항목노드["자식들"][1])
        만약 신호오류인지(sg값): 반환 sg값
        문자 키문자 = 값문자열변환(sg키["값"])
        결과[키문자] = sg값["값"]
    반환 신호정상(값만들기사전(결과))

// ================================================================
//  인덱스 읽기 (NODE_INDEX)
//  배열[i], 사전["키"], 문자열[i]
// ================================================================

함수 인덱스평가(목록 인터프리터, 목록 환경, 목록 노드):
    목록 sg대상 = 노드평가(인터프리터, 환경, 노드["자식들"][0])
    만약 신호오류인지(sg대상): 반환 sg대상
    목록 sg키 = 노드평가(인터프리터, 환경, 노드["자식들"][1])
    만약 신호오류인지(sg키): 반환 sg키
    목록 대상 = sg대상["값"]
    목록 키값 = sg키["값"]
    정수 줄 = 노드["줄"]
    정수 열 = 노드["열"]

    만약 대상["타입"] == VAL_배열:
        만약 키값["타입"] != VAL_정수:
            반환 신호오류위치(ERR_타입, "배열 인덱스는 정수여야 합니다", 줄, 열)
        정수 인덱스 = 키값["정수값"]
        정수 배열길이 = 길이(대상["참조값"])
        만약 인덱스 < 0: 인덱스 = 배열길이 + 인덱스
        만약 인덱스 < 0 또는 인덱스 >= 배열길이:
            반환 신호오류위치(ERR_범위,
                "배열 인덱스 " + 문자(인덱스) + " 가 범위를 벗어났습니다", 줄, 열)
        반환 신호정상(대상["참조값"][인덱스])

    만약 대상["타입"] == VAL_사전:
        문자 키문자 = 값문자열변환(키값)
        만약 아니다 (대상["참조값"] 포함(키문자)):
            반환 신호오류위치(ERR_키없음,
                "사전에 키 '" + 키문자 + "' 가 없습니다", 줄, 열)
        반환 신호정상(대상["참조값"][키문자])

    만약 대상["타입"] == VAL_문자:
        만약 키값["타입"] != VAL_정수:
            반환 신호오류위치(ERR_타입, "문자열 인덱스는 정수여야 합니다", 줄, 열)
        정수 인덱스 = 키값["정수값"]
        정수 문자길이 = 길이(대상["문자값"])
        만약 인덱스 < 0: 인덱스 = 문자길이 + 인덱스
        만약 인덱스 < 0 또는 인덱스 >= 문자길이:
            반환 신호오류위치(ERR_범위,
                "문자열 인덱스 " + 문자(인덱스) + " 가 범위를 벗어났습니다", 줄, 열)
        반환 신호정상(값만들기문자(대상["문자값"][인덱스]))

    반환 신호오류위치(ERR_타입,
        "'" + 값타입이름(대상["타입"]) + "' 는 인덱스 접근을 지원하지 않습니다", 줄, 열)

// ================================================================
//  멤버 읽기 (NODE_MEMBER)
//  목록.속성, 사전.속성, 객체.속성
// ================================================================

함수 멤버평가(목록 인터프리터, 목록 환경, 목록 노드):
    목록 sg = 노드평가(인터프리터, 환경, 노드["자식들"][0])
    만약 신호오류인지(sg): 반환 sg
    목록 대상 = sg["값"]
    문자 멤버명 = 노드["문자열"]
    정수 줄 = 노드["줄"]
    정수 열 = 노드["열"]

    만약 대상["타입"] == VAL_사전 또는 대상["타입"] == VAL_목록:
        만약 아니다 (대상["참조값"] 포함(멤버명)):
            반환 신호오류위치(ERR_속성,
                "'" + 멤버명 + "' 속성이 없습니다", 줄, 열)
        반환 신호정상(대상["참조값"][멤버명])

    만약 대상["타입"] == VAL_객체:
        목록 결과 = 객체멤버탐색(대상, 멤버명)
        만약 결과 == 없음:
            반환 신호오류위치(ERR_속성,
                "객체에 '" + 멤버명 + "' 속성/메서드가 없습니다", 줄, 열)
        반환 신호정상(결과)

    반환 신호오류위치(ERR_타입,
        "'" + 값타입이름(대상["타입"]) + "' 는 멤버 접근을 지원하지 않습니다", 줄, 열)

// ================================================================
//  만약 실행 (NODE_IF / NODE_ELIF / NODE_ELSE)
// ================================================================

함수 만약실행(목록 인터프리터, 목록 환경, 목록 노드):
    배열 자식들 = 노드["자식들"]
 // 조건 평가
    목록 sg = 노드평가(인터프리터, 환경, 자식들[0])
    만약 신호오류인지(sg): 반환 sg
    만약 값참인지(sg["값"]):
        반환 블록실행(인터프리터, 환경, 자식들[1])
 // 아니면 만약 / 아니면 처리
    반복 i 부터 2 까지 길이(자식들):
        목록 분기 = 자식들[i]
        만약 분기["종류"] == NODE_ELIF:
            목록 sg2 = 노드평가(인터프리터, 환경, 분기["자식들"][0])
            만약 신호오류인지(sg2): 반환 sg2
            만약 값참인지(sg2["값"]):
                반환 블록실행(인터프리터, 환경, 분기["자식들"][1])
        아니면 만약 분기["종류"] == NODE_ELSE:
            반환 블록실행(인터프리터, 환경, 분기["자식들"][0])

    반환 신호정상(값없음())

// ================================================================
//  동안 실행 (NODE_WHILE)
// ================================================================

함수 동안실행(목록 인터프리터, 목록 환경, 목록 노드):
    목록 조건노드 = 노드["자식들"][0]
    목록 본문 = 노드["자식들"][1]
    목록 결과 = 신호정상(값없음())
    논리 루프중 = 참

    동안 루프중:
        목록 sg조건 = 노드평가(인터프리터, 환경, 조건노드)
        만약 신호오류인지(sg조건):
            결과 = sg조건
            루프중 = 거짓
        아니면 만약 아니다 값참인지(sg조건["값"]):
            루프중 = 거짓
        아니면:
            목록 sg본문 = 블록실행(인터프리터, 환경, 본문)
            만약 sg본문["종류"] == SIG_멈춤:
                루프중 = 거짓
            아니면 만약 sg본문["종류"] == SIG_건너뜀:
                루프중 = 루프중   // 조건으로 돌아감 (noop)
            아니면 만약 sg본문["종류"] != SIG_정상:
                결과 = sg본문
                루프중 = 거짓

    반환 결과

// ================================================================
//  반복 실행 (NODE_FOR_RANGE)
//  반복 변수 부터 시작 까지 끝:           → 자식 3개
//  반복 변수 부터 시작 까지 끝, step:     → 자식 4개
// ================================================================

함수 반복실행(목록 인터프리터, 목록 환경, 목록 노드):
    문자 변수명 = 노드["문자열"]
    배열 자식들 = 노드["자식들"]
    정수 자식수 = 길이(자식들)
    정수 줄 = 노드["줄"]
    정수 열 = 노드["열"]

    목록 sg시작 = 노드평가(인터프리터, 환경, 자식들[0])
    만약 신호오류인지(sg시작): 반환 sg시작
    목록 sg끝 = 노드평가(인터프리터, 환경, 자식들[1])
    만약 신호오류인지(sg끝): 반환 sg끝
 // step 유무에 따라 블록 위치 결정
    정수 step = 1
    목록 블록노드 = 없음
    만약 자식수 == 3:
        블록노드 = 자식들[2]
    아니면:
        목록 sg스텝 = 노드평가(인터프리터, 환경, 자식들[2])
        만약 신호오류인지(sg스텝): 반환 sg스텝
        만약 sg스텝["값"]["타입"] != VAL_정수:
            반환 신호오류위치(ERR_타입, "반복 step 은 정수여야 합니다", 줄, 열)
        step = sg스텝["값"]["정수값"]
        블록노드 = 자식들[3]

    만약 sg시작["값"]["타입"] != VAL_정수:
        반환 신호오류위치(ERR_타입, "반복 시작값은 정수여야 합니다", 줄, 열)
    만약 sg끝["값"]["타입"] != VAL_정수:
        반환 신호오류위치(ERR_타입, "반복 끝값은 정수여야 합니다", 줄, 열)
    만약 step == 0:
        반환 신호오류위치(ERR_인수, "반복 step 이 0 입니다", 줄, 열)

    정수 i = sg시작["값"]["정수값"]
    정수 끝 = sg끝["값"]["정수값"]
    목록 결과 = 신호정상(값없음())
    논리 루프중 = 참

    동안 루프중: // 범위 체크 (step 방향에 따라)
        만약 step > 0 그리고 i >= 끝:
            루프중 = 거짓
        아니면 만약 step < 0 그리고 i <= 끝:
            루프중 = 거짓
        아니면:
            목록 루프환경 = 환경만들기(환경)
            환경변수정의(루프환경, 변수명, 값만들기정수(i), 거짓)
            목록 sg = 블록실행(인터프리터, 루프환경, 블록노드)
            만약 sg["종류"] == SIG_멈춤:
                루프중 = 거짓
            아니면 만약 sg["종류"] == SIG_건너뜀:
                i = i + step
            아니면 만약 sg["종류"] == SIG_정상:
                i = i + step
            아니면:
                결과 = sg
                루프중 = 거짓

    반환 결과

// ================================================================
//  각각 실행 (NODE_FOR_EACH)
//  각각 변수 안에 컬렉션:
// ================================================================

함수 각각실행(목록 인터프리터, 목록 환경, 목록 노드):
    문자 변수명 = 노드["문자열"]
    목록 블록노드 = 노드["자식들"][1]
    정수 줄 = 노드["줄"]
    정수 열 = 노드["열"]

    목록 sg = 노드평가(인터프리터, 환경, 노드["자식들"][0])
    만약 신호오류인지(sg): 반환 sg
    목록 이터러블 = sg["값"]
    목록 결과 = 신호정상(값없음())
    논리 루프중 = 참
 // ── 배열 순회 ───────────────────────────────────────
    만약 이터러블["타입"] == VAL_배열:
        정수 i = 0
        정수 배열길이 = 길이(이터러블["참조값"])
        동안 루프중:
            만약 i >= 배열길이:
                루프중 = 거짓
            아니면:
                목록 루프환경 = 환경만들기(환경)
                환경변수정의(루프환경, 변수명,
                    이터러블["참조값"][i], 거짓)
                목록 sg본문 = 블록실행(인터프리터, 루프환경, 블록노드)
                만약 sg본문["종류"] == SIG_멈춤:
                    루프중 = 거짓
                아니면 만약 sg본문["종류"] == SIG_건너뜀:
                    i = i + 1
                아니면 만약 sg본문["종류"] == SIG_정상:
                    i = i + 1
                아니면:
                    결과 = sg본문
                    루프중 = 거짓
 // ── 문자열 순회 ─────────────────────────────────────
    아니면 만약 이터러블["타입"] == VAL_문자:
        정수 i = 0
        문자 문자열 = 이터러블["문자값"]
        정수 문자길이 = 길이(문자열)
        동안 루프중:
            만약 i >= 문자길이:
                루프중 = 거짓
            아니면:
                목록 루프환경 = 환경만들기(환경)
                환경변수정의(루프환경, 변수명,
                    값만들기문자(문자열[i]), 거짓)
                목록 sg본문 = 블록실행(인터프리터, 루프환경, 블록노드)
                만약 sg본문["종류"] == SIG_멈춤:
                    루프중 = 거짓
                아니면 만약 sg본문["종류"] == SIG_건너뜀:
                    i = i + 1
                아니면 만약 sg본문["종류"] == SIG_정상:
                    i = i + 1
                아니면:
                    결과 = sg본문
                    루프중 = 거짓

    아니면:
        반환 신호오류위치(ERR_타입,
            "'" + 값타입이름(이터러블["타입"]) + "' 은 순회할 수 없습니다", 줄, 열)

    반환 결과

// ================================================================
//  선택 실행 (NODE_SWITCH / NODE_CASE / NODE_DEFAULT)
// ================================================================

함수 선택실행(목록 인터프리터, 목록 환경, 목록 노드):
    배열 자식들 = 노드["자식들"]
 // child[0] = 대상 표현식
    목록 sg대상 = 노드평가(인터프리터, 환경, 자식들[0])
    만약 신호오류인지(sg대상): 반환 sg대상
    목록 대상값 = sg대상["값"]
 // child[1..] = 경우 / 그외
    반복 i 부터 1 까지 길이(자식들):
        목록 경우노드 = 자식들[i]
        만약 경우노드["종류"] == NODE_CASE:
            목록 sg경우 = 노드평가(인터프리터, 환경, 경우노드["자식들"][0])
            만약 신호오류인지(sg경우): 반환 sg경우
            만약 값같은지(대상값, sg경우["값"]):
                목록 sg = 블록실행(인터프리터, 환경, 경우노드["자식들"][1]) // 멈춤 → 선택문 종료 (정상)
                만약 sg["종류"] == SIG_멈춤:
                    반환 신호정상(값없음())
                반환 sg
        아니면 만약 경우노드["종류"] == NODE_DEFAULT:
            목록 sg = 블록실행(인터프리터, 환경, 경우노드["자식들"][0])
            만약 sg["종류"] == SIG_멈춤:
                반환 신호정상(값없음())
            반환 sg

    반환 신호정상(값없음())

// ================================================================
//  블록 실행
// ================================================================

함수 블록실행(목록 인터프리터, 목록 환경, 목록 블록):
    목록 블록환경 = 환경만들기(환경)
    배열 자식들 = 블록["자식들"]
    정수 자식수 = 길이(자식들)
    정수 i = 0
    동안 i < 자식수:
        목록 sg = 구문실행(인터프리터, 블록환경, 자식들[i])
        만약 sg["종류"] == SIG_이동: // goto: 현재 블록에서 레이블 탐색
            문자 목표 = sg["이동목표"]
            논리 찾음 = 거짓
            반복 j 부터 0 까지 자식수:
                만약 자식들[j]["종류"] == NODE_LABEL 그리고 자식들[j]["문자열"] == 목표:
                    i = j   // 레이블 위치로 점프 (NODE_LABEL은 정상 반환)
                    찾음 = 참
                    멈춤
            만약 아니다 찾음:
                반환 sg   // 상위 블록으로 전파
        아니면 만약 신호전파인지(sg):
            반환 sg
        아니면:
            i = i + 1
    반환 신호정상(값없음())

// ================================================================
//  구문 실행 — 메인 디스패치
// ================================================================

함수 구문실행(목록 인터프리터, 목록 환경, 목록 노드):
    만약 노드 == 없음:
        반환 신호정상(값없음())
    정수 종류 = 노드["종류"]
 // 변수 / 상수 선언
    만약 종류 == NODE_VAR_DECL 또는 종류 == NODE_CONST_DECL:
        반환 변수선언실행(인터프리터, 환경, 노드)
 // 표현식 구문
    만약 종류 == NODE_EXPR_STMT:
        만약 길이(노드["자식들"]) > 0:
            목록 sg = 노드평가(인터프리터, 환경, 노드["자식들"][0])
            만약 신호오류인지(sg): 반환 sg
        반환 신호정상(값없음())
 // 블록
    만약 종류 == NODE_BLOCK:
        반환 블록실행(인터프리터, 환경, 노드)
 // ── 2단계: 제어 흐름 ────────────────────────────────
    만약 종류 == NODE_IF:
        반환 만약실행(인터프리터, 환경, 노드)
    만약 종류 == NODE_WHILE:
        반환 동안실행(인터프리터, 환경, 노드)
    만약 종류 == NODE_FOR_RANGE:
        반환 반복실행(인터프리터, 환경, 노드)
    만약 종류 == NODE_FOR_EACH:
        반환 각각실행(인터프리터, 환경, 노드)
    만약 종류 == NODE_SWITCH:
        반환 선택실행(인터프리터, 환경, 노드)
 // ── 2단계: 흐름 제어 신호 ────────────────────────────
    만약 종류 == NODE_BREAK:
        반환 신호멈춤()
    만약 종류 == NODE_CONTINUE:
        반환 신호건너뜀()
    만약 종류 == NODE_RETURN:
        만약 길이(노드["자식들"]) > 0:
            목록 sg = 노드평가(인터프리터, 환경, 노드["자식들"][0])
            만약 신호오류인지(sg): 반환 sg
            반환 신호반환(sg["값"])
        반환 신호끝냄()
    만약 종류 == NODE_RAISE:
        만약 길이(노드["자식들"]) > 0:
            목록 sg = 노드평가(인터프리터, 환경, 노드["자식들"][0])
            만약 신호오류인지(sg): 반환 sg
            반환 신호오류위치(ERR_사용자,
                값문자열변환(sg["값"]), 노드["줄"], 노드["열"])
        반환 신호오류위치(ERR_사용자, "오류 발생", 노드["줄"], 노드["열"])
 // ── 3단계: 함수 / 정의 선언 ─────────────────────────
    만약 종류 == NODE_FUNC_DECL 또는 종류 == NODE_VOID_DECL:
        반환 함수선언실행(인터프리터, 환경, 노드)
 // ── 6단계: 클래스 선언 ───────────────────────────────
    만약 종류 == NODE_CLASS_DECL:
        반환 클래스선언실행(인터프리터, 환경, 노드)
 // ── 7단계: 예외처리 + goto/label ────────────────────
    만약 종류 == NODE_TRY:
        반환 시도실행(인터프리터, 환경, 노드)
    만약 종류 == NODE_GOTO:
        반환 신호이동(노드["문자열"])
    만약 종류 == NODE_LABEL:
        반환 신호정상(값없음())
 // ── 8단계: 모듈 + 스크립트 ──────────────────────────
    만약 종류 == NODE_PP_STMT:
        반환 포함실행(인터프리터, 환경, 노드)
    만약 종류 == NODE_IMPORT:
        반환 가져오기실행(인터프리터, 환경, 노드)
    만약 종류 == NODE_SCRIPT_PYTHON 또는 종류 == NODE_SCRIPT_JAVA 또는
         종류 == NODE_SCRIPT_JS     또는 종류 == NODE_SCRIPT_TS:
        반환 스크립트실행(인터프리터, 환경, 노드)
 // ── 나머지는 이후 단계에서 구현 ─────────────────────
    반환 신호오류위치(ERR_내부,
        "미구현 구문 노드 '" + 노드이름(종류) + "'",
        노드["줄"], 노드["열"])

// ================================================================
//  인터프리터 실행 (진입점)
// ================================================================

함수 인터프리터실행(목록 인터프리터, 목록 ast):
    만약 ast == 없음:
        반환 신호오류(ERR_내부, "AST 가 없습니다")
 // ── 10단계: .kwh 힌트 적재 ──────────────────────────────────
    kwh적재(인터프리터)

    목록 결과 = 신호정상(값없음())
 // NODE_PROGRAM 최상위 처리
    만약 ast["종류"] == NODE_PROGRAM:
        각각 구문 안에 ast["자식들"]:
            목록 sg = 구문실행(인터프리터, 인터프리터["전역환경"], 구문)
            만약 sg["종류"] == SIG_오류:
                인터프리터["오류있음"] = 참
                출력(sg["오류메시지"])
                결과 = sg
                멈춤
            만약 sg["종류"] == SIG_반환 또는 sg["종류"] == SIG_끝냄:
                결과 = sg
                멈춤
    아니면: // 단일 노드 직접 실행
        결과 = 구문실행(인터프리터, 인터프리터["전역환경"], ast)
 // ── 10단계: .kwh 힌트 저장 ──────────────────────────────────
    kwh저장(인터프리터)

    반환 결과

// ================================================================
//  ★ 3단계: 함수/정의 선언 + 호출 + 람다 + 메서드 + 내장 함수
// ================================================================

// ── 값 얕은 복사 ─────────────────────────────────────────────────

함수 값복사(목록 val):
    목록 새val = 값없음()
    새val["타입"]   = val["타입"]
    새val["정수값"] = val["정수값"]
    새val["실수값"] = val["실수값"]
    새val["논리값"] = val["논리값"]
    새val["문자값"] = val["문자값"]
    새val["참조값"] = val["참조값"]
    반환 새val

// ── 함수 선언 실행 (NODE_FUNC_DECL / NODE_VOID_DECL) ─────────────

함수 함수선언실행(목록 인터프리터, 목록 환경, 목록 노드):
    문자 이름 = 노드["문자열"]
    목록 함수값 = 값만들기함수(노드, 환경)
    환경변수정의(환경, 이름, 함수값, 거짓)
    반환 신호정상(값없음())

// ── 람다 평가 (NODE_LAMBDA) ──────────────────────────────────────

함수 람다평가(목록 인터프리터, 목록 환경, 목록 노드):
    반환 신호정상(값만들기람다(노드, 환경))

// ── 함수 호출 (사용자 정의 함수 / 람다 공통) ─────────────────────
//  NODE_FUNC_DECL 자식들 = [PARAM..., BLOCK]
//  NODE_LAMBDA    자식들 = [PARAM..., 본문expr]

함수 함수호출(목록 인터프리터, 목록 함수값, 배열 인수들, 정수 줄, 정수 열):
    만약 인터프리터["호출깊이"] >= KCODE_MAX_CALL_DEPTH:
        반환 신호오류위치(ERR_스택, "호출 스택이 넘쳤습니다", 줄, 열)

    목록 정보 = 함수값["참조값"]
    목록 노드 = 정보["노드"]
    목록 클로저 = 정보["클로저"]
    배열 자식들 = 노드["자식들"]
    정수 자식수 = 길이(자식들)
 // 마지막 자식이 BLOCK이면 함수, 아니면 람다(표현식 본문)
    배열 매개변수들 = []
    목록 본문 = 없음
    논리 람다형 = 거짓

    만약 자식수 > 0:
        만약 자식들[자식수 - 1]["종류"] == NODE_BLOCK:
            반복 i 부터 0 까지 자식수 - 1:
                매개변수들 추가(자식들[i])
            본문 = 자식들[자식수 - 1]
        아니면:
            반복 i 부터 0 까지 자식수 - 1:
                매개변수들 추가(자식들[i])
            본문 = 자식들[자식수 - 1]
            람다형 = 참
 // 클로저 기반 호출 환경
    목록 호출환경 = 환경만들기(클로저)
 // 매개변수 바인딩
    정수 인수수 = 길이(인수들)
    정수 매개수 = 길이(매개변수들)
    정수 p = 0
    논리 루프중 = 참

    동안 루프중:
        만약 p >= 매개수:
            루프중 = 거짓
        아니면:
            목록 param = 매개변수들[p]
            문자 param이름 = param["문자열"]
            논리 가변 = param 포함("...") 그리고 param["..."] != 없음 그리고 param["..."]
            만약 가변:
                배열 나머지 = []
                반복 j 부터 p 까지 인수수:
                    나머지 추가(인수들[j])
                환경변수정의(호출환경, param이름, 값만들기배열(나머지), 거짓)
                루프중 = 거짓
            아니면 만약 p < 인수수:
                환경변수정의(호출환경, param이름, 인수들[p], 거짓)
                p = p + 1
            아니면:
                만약 길이(param["자식들"]) > 0:
                    목록 sg기본 = 노드평가(인터프리터, 환경만들기(클로저), param["자식들"][0])
                    만약 신호오류인지(sg기본): 반환 sg기본
                    환경변수정의(호출환경, param이름, sg기본["값"], 거짓)
                아니면:
                    반환 신호오류위치(ERR_인수,
                        "매개변수 '" + param이름 + "' 에 값이 없습니다", 줄, 열)
                p = p + 1
 // 실행
    인터프리터["호출깊이"] = 인터프리터["호출깊이"] + 1
    목록 sg = 없음

    만약 람다형:
        sg = 노드평가(인터프리터, 호출환경, 본문)
        인터프리터["호출깊이"] = 인터프리터["호출깊이"] - 1
        만약 신호오류인지(sg): 반환 sg
        반환 신호정상(sg["값"])
    아니면:
        sg = 블록실행(인터프리터, 호출환경, 본문)
        인터프리터["호출깊이"] = 인터프리터["호출깊이"] - 1
        만약 sg["종류"] == SIG_반환: 반환 신호정상(sg["값"])
        만약 sg["종류"] == SIG_끝냄: 반환 신호정상(값없음())
        반환 sg

// ── 내장 함수 호출 ───────────────────────────────────────────────

함수 내장함수호출(목록 인터프리터, 문자 이름, 배열 인수들, 정수 줄, 정수 열):
    정수 인수수 = 길이(인수들)

    만약 이름 == "출력":
        문자 출력문 = ""
        반복 i 부터 0 까지 인수수:
            만약 i > 0: 출력문 = 출력문 + " "
            출력문 = 출력문 + 값문자열변환(인수들[i])
        출력(출력문)
        반환 신호정상(값없음())

    만약 이름 == "출력없이":
        문자 출력문 = ""
        반복 i 부터 0 까지 인수수:
            만약 i > 0: 출력문 = 출력문 + " "
            출력문 = 출력문 + 값문자열변환(인수들[i])
        출력없이(출력문)
        반환 신호정상(값없음())

    만약 이름 == "입력":
        문자 안내 = ""
        만약 인수수 > 0: 안내 = 값문자열변환(인수들[0])
        문자 결과 = 입력(안내)
        반환 신호정상(값만들기문자(결과))

    만약 이름 == "길이":
        만약 인수수 != 1:
            반환 신호오류위치(ERR_인수, "길이() 는 인수 1개가 필요합니다", 줄, 열)
        목록 val = 인수들[0]
        만약 val["타입"] == VAL_문자:
            반환 신호정상(값만들기정수(길이(val["문자값"])))
        만약 val["타입"] == VAL_배열:
            반환 신호정상(값만들기정수(길이(val["참조값"])))
        만약 val["타입"] == VAL_사전 또는 val["타입"] == VAL_목록:
            반환 신호정상(값만들기정수(길이(val["참조값"])))
        반환 신호오류위치(ERR_타입, "길이() 는 문자·배열·사전에만 사용 가능합니다", 줄, 열)

    만약 이름 == "문자":
        만약 인수수 != 1:
            반환 신호오류위치(ERR_인수, "문자() 는 인수 1개가 필요합니다", 줄, 열)
        반환 신호정상(값만들기문자(값문자열변환(인수들[0])))

    만약 이름 == "정수":
        만약 인수수 != 1:
            반환 신호오류위치(ERR_인수, "정수() 는 인수 1개가 필요합니다", 줄, 열)
        목록 val = 인수들[0]
        만약 val["타입"] == VAL_정수: 반환 신호정상(val)
        만약 val["타입"] == VAL_실수:
            반환 신호정상(값만들기정수(정수(val["실수값"])))
        만약 val["타입"] == VAL_문자:
            반환 신호정상(값만들기정수(정수(val["문자값"])))
        만약 val["타입"] == VAL_논리:
            만약 val["논리값"]: 반환 신호정상(값만들기정수(1))
            반환 신호정상(값만들기정수(0))
        반환 신호오류위치(ERR_타입, "정수() 변환 불가: " + 값타입이름(val["타입"]), 줄, 열)

    만약 이름 == "실수":
        만약 인수수 != 1:
            반환 신호오류위치(ERR_인수, "실수() 는 인수 1개가 필요합니다", 줄, 열)
        목록 val = 인수들[0]
        만약 val["타입"] == VAL_실수: 반환 신호정상(val)
        만약 val["타입"] == VAL_정수:
            반환 신호정상(값만들기실수(실수(val["정수값"])))
        만약 val["타입"] == VAL_문자:
            반환 신호정상(값만들기실수(실수(val["문자값"])))
        반환 신호오류위치(ERR_타입, "실수() 변환 불가: " + 값타입이름(val["타입"]), 줄, 열)

    만약 이름 == "글자":
        만약 인수수 != 1:
            반환 신호오류위치(ERR_인수, "글자() 는 인수 1개가 필요합니다", 줄, 열)
        목록 val = 인수들[0]
        만약 val["타입"] != VAL_정수:
            반환 신호오류위치(ERR_타입, "글자() 는 정수가 필요합니다", 줄, 열)
        반환 신호정상(값만들기글자(val["정수값"]))

    만약 이름 == "코드":
        만약 인수수 != 1:
            반환 신호오류위치(ERR_인수, "코드() 는 인수 1개가 필요합니다", 줄, 열)
        목록 val = 인수들[0]
        만약 val["타입"] == VAL_글자:
            반환 신호정상(값만들기정수(val["정수값"]))
        만약 val["타입"] == VAL_문자:
            만약 길이(val["문자값"]) == 0:
                반환 신호오류위치(ERR_인수, "코드() 빈 문자열입니다", 줄, 열)
            반환 신호정상(값만들기정수(코드(val["문자값"][0])))
        반환 신호오류위치(ERR_타입, "코드() 는 글자 또는 문자가 필요합니다", 줄, 열)

    만약 이름 == "유형":
        만약 인수수 != 1:
            반환 신호오류위치(ERR_인수, "유형() 는 인수 1개가 필요합니다", 줄, 열)
        반환 신호정상(값만들기문자(값타입이름(인수들[0]["타입"])))

    만약 이름 == "복사":
        만약 인수수 != 1:
            반환 신호오류위치(ERR_인수, "복사() 는 인수 1개가 필요합니다", 줄, 열)
        반환 신호정상(값복사(인수들[0]))

    만약 이름 == "범위":
        만약 인수수 < 1 또는 인수수 > 3:
            반환 신호오류위치(ERR_인수, "범위() 는 인수 1~3개가 필요합니다", 줄, 열)
        정수 시작 = 0
        정수 끝 = 0
        정수 step = 1
        만약 인수수 == 1:
            만약 인수들[0]["타입"] != VAL_정수:
                반환 신호오류위치(ERR_타입, "범위() 인수는 정수여야 합니다", 줄, 열)
            끝 = 인수들[0]["정수값"]
        아니면 만약 인수수 == 2:
            만약 인수들[0]["타입"] != VAL_정수 또는 인수들[1]["타입"] != VAL_정수:
                반환 신호오류위치(ERR_타입, "범위() 인수는 정수여야 합니다", 줄, 열)
            시작 = 인수들[0]["정수값"]
            끝 = 인수들[1]["정수값"]
        아니면:
            만약 인수들[0]["타입"] != VAL_정수 또는
                 인수들[1]["타입"] != VAL_정수 또는
                 인수들[2]["타입"] != VAL_정수:
                반환 신호오류위치(ERR_타입, "범위() 인수는 정수여야 합니다", 줄, 열)
            시작 = 인수들[0]["정수값"]
            끝 = 인수들[1]["정수값"]
            step = 인수들[2]["정수값"]
        만약 step == 0:
            반환 신호오류위치(ERR_인수, "범위() step 이 0 입니다", 줄, 열)
        배열 결과 = []
        정수 i = 시작
        논리 루프중 = 참
        동안 루프중:
            만약 step > 0 그리고 i >= 끝: 루프중 = 거짓
            아니면 만약 step < 0 그리고 i <= 끝: 루프중 = 거짓
            아니면:
                결과 추가(값만들기정수(i))
                i = i + step
        반환 신호정상(값만들기배열(결과))
 // ================================================================ //  ★ 5단계: 수학 함수 / 통계 함수 / 문자열 함수 // ================================================================
 // ── 수 추출 보조 (인수가 정수/실수면 실수로 변환) ──────────────── //  수학 함수 내에서 공통 사용
 // ── 수학: 단항 (절대, 올림, 내림, 반올림, 제곱근, 사인 ...) ─────

    만약 이름 == "절대":
