        실수 x = 0.0
        만약 v["타입"] == VAL_실수: x = v["실수값"]
        아니면: x = 실수(v["정수값"])
        반환 신호정상(값만들기실수(제곱근(x)))

    만약 이름 == "로그": // 로그(수, 밑?) — 밑 생략시 상용로그(log10)
        만약 인수수 < 1 또는 인수수 > 2:
            반환 신호오류위치(ERR_인수, "로그() 는 인수 1~2개가 필요합니다", 줄, 열)
        목록 v = 인수들[0]
        만약 v["타입"] != VAL_정수 그리고 v["타입"] != VAL_실수:
            반환 신호오류위치(ERR_타입, "로그() 는 숫자가 필요합니다", 줄, 열)
        실수 x = 0.0
        만약 v["타입"] == VAL_실수: x = v["실수값"]
        아니면: x = 실수(v["정수값"])
        만약 인수수 == 1:
            반환 신호정상(값만들기실수(로그(x)))
        실수 밑 = 0.0
        만약 인수들[1]["타입"] == VAL_실수: 밑 = 인수들[1]["실수값"]
        아니면: 밑 = 실수(인수들[1]["정수값"])
        반환 신호정상(값만들기실수(로그(x, 밑)))

    만약 이름 == "자연로그":
        만약 인수수 != 1:
            반환 신호오류위치(ERR_인수, "자연로그() 는 인수 1개가 필요합니다", 줄, 열)
        목록 v = 인수들[0]
