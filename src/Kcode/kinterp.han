        실수 y = 0.0
        실수 x = 0.0
        만약 인수들[0]["타입"] == VAL_실수: y = 인수들[0]["실수값"]
        아니면: y = 실수(인수들[0]["정수값"])
        만약 인수들[1]["타입"] == VAL_실수: x = 인수들[1]["실수값"]
